#!/usr/bin/env bash
set -euo pipefail

# Local-only helper:
# - If staged changes touch likely source files, regenerate mermaid_output.
# - mermaid_output is gitignored in this repo by default; regeneration is for local AI use.

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOL_DIR="$(cd "$HOOK_DIR/.." && pwd)"
ROOT_DIR="$(git -C "$TOOL_DIR" rev-parse --show-toplevel 2>/dev/null || echo "$TOOL_DIR")"

changed_files="$(cd "$ROOT_DIR" && git diff --cached --name-only)"
if [[ -z "${changed_files}" ]]; then
  exit 0
fi

should_regen="false"
while IFS= read -r f; do
  case "$f" in
    *.py|*.xml|*.js|*.ts|*.scss|*.csv|*.yml|*.yaml)
      should_regen="true"
      break
      ;;
  esac
done <<< "$changed_files"

if [[ "$should_regen" != "true" ]]; then
  exit 0
fi

echo "[pre-commit] Changes detected; regenerating mermaid_output…"
"$TOOL_DIR/scripts/regenerate_mermaid_output.sh"

